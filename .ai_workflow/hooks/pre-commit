#!/bin/bash
# ---------------------------------------------------------
# [决策中枢定制] 适配探针架构的 Pre-commit 门控
# ---------------------------------------------------------

echo "[GATE] 启动架构探针扫描..."

# 1. 基础物理安全扫描 (本地 AST 静态分析，无需 API Key)
if [ -f ".ai_workflow/pre_execution_check.py" ]; then
    python .ai_workflow/pre_execution_check.py
    if [ $? -ne 0 ]; then
        echo "[FATAL] 代码中存在非法 eval/exec 注入风险，禁止提交！"
        exit 1
    fi
fi

# 2. 检查 .env 状态 (降级警告模式)
if [ ! -f ".env" ]; then
    echo "[WARN] .env 缺失：云端审计大脑 (Gemini) 已降级为本地探针模式。"
fi

# 3. 接口稳定性扫描
# 获取已暂存的 Python 文件
staged_files=$(git diff --cached --name-only | grep '\.py$')

if [ -n "$staged_files" ]; then
    echo "[GATE] 检测到接口变更，执行稳定性探针..."
    for file in $staged_files; do
        if [ -f ".ai_workflow/post_check_diff.py" ]; then
            # 运行本地 Diff 探针
            python .ai_workflow/post_check_diff.py "$file" --ref HEAD
            if [ $? -ne 0 ]; then
                echo "[WARN] 接口结构发生了非标准变更，请确认是否符合架构契约。"
                # 如果你希望强制拦截，将下面的 exit 0 改为 exit 1
                exit 0
            fi
        fi
    done
fi

echo "[SUCCESS] 探针扫描通过，允许提交。"
exit 0