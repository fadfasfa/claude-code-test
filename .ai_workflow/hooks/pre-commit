#!/bin/bash
staged_files=$(git diff --cached --name-only | grep '\.py$')
if [ -z "$staged_files" ]; then
    exit 0
fi

failed=0
for file in $staged_files; do
    if [! -f "$file" ]; then continue; fi

    python -c "
import sys
import os

sys.path.insert(0, os.path.join(os.getcwd(), '.ai_workflow'))

try:
    from pre_execution_check import check_dangerous_calls
except ImportError as e:
    print(f' Failed to import module: {e}')
    sys.exit(1)

file_path = '$file'
if file_path.startswith('.ai_workflow/') or file_path.startswith('scripts/'):
    sys.exit(0)

try:
    with open(file_path, 'r', encoding='utf-8') as f:
        code = f.read()
    is_safe, violations = check_dangerous_calls(code, exempted_modules=)
    if not is_safe:
        print(f' AST intercept [{file_path}]:')
        for v in violations:
            print(f'  - {v}')
        sys.exit(1)
except Exception as e:
    print(f' Scanner exception: {e}')
    sys.exit(1)
"
    if [ $? -ne 0 ]; then
        failed=1
    fi
done

if [ $failed -ne 0 ]; then
    echo " Git pre-commit hook check failed, commit aborted"
    exit 1
fi

echo " AST security scan passed. Waking up Cloud Brain (Gemini)..."

# ==========================================
# 唤醒云端 Gemini 进行语义审查
# ==========================================
python.ai_workflow/audit_dispatch.py
if [ $? -ne 0 ]; then
    echo " Cloud Brain rejected the commit or encountered an error."
    exit 1
fi

echo " Cloud Audit Passed! Commit successful."
exit 0