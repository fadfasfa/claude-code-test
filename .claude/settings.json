{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_FORK_SUBAGENT": "0"
  },
  "permissions": {
    "deny": [
      "PowerShell(Remove-Item*)",
      "PowerShell(rm -r*)",
      "PowerShell(rm -rf*)",
      "PowerShell(git clean*)",
      "PowerShell(git reset --hard*)",
      "PowerShell(git branch -D*)",
      "PowerShell(git worktree remove --force*)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)",
      "Bash(rm -r*)",
      "Bash(rm -rf*)",
      "Bash(git clean*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git worktree remove --force*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.kube/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.kube/**)"
    ]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\apple\\claudecode\\.claude\\hooks\\worktree-governor-create.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\apple\\claudecode\\.claude\\hooks\\worktree-governor-remove.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\apple\\claudecode\\.claude\\hooks\\block-builtin-explore.ps1\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\apple\\claudecode\\.claude\\hooks\\block-raw-worktree-bash.ps1\"",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "planning-with-files": {
      "source": {
        "source": "github",
        "repo": "OthmanAdi/planning-with-files"
      }
    }
  },
  "plansDirectory": ".tmp/claude-plans",
  "enabledPlugins": {
    "planning-with-files@planning-with-files": true
  }
}
